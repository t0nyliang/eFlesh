# 25x25x20mm rectangular box for eFlesh forearm pad
# 8 vertices, 12 triangulated faces with outward-facing normals
# Units: mm

v 0 0 0
v 25 0 0
v 25 25 0
v 0 25 0
v 0 0 20
v 25 0 20
v 25 25 20
v 0 25 20

# Bottom face (Z=0, normal -Z)
f 1 3 2
f 1 4 3
# Top face (Z=20, normal +Z)
f 5 6 8
f 6 7 8
# Front face (Y=0, normal -Y)
f 1 2 6
f 1 6 5
# Back face (Y=25, normal +Y)
f 3 4 8
f 3 8 7
# Left face (X=0, normal -X)
f 1 5 8
f 1 8 4
# Right face (X=25, normal +X)
f 2 3 7
f 2 7 6
